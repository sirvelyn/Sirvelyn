{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sirvelyn",
  "version": "0.1.0",
  "identifier": "com.sirvelyn.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sirvelyn",
        "width": 1180,
        "height": 760,
        "minWidth": 860,
        "minHeight": 540,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sirvelyn/Sirvelyn/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCRjkwRjAzMTQ0QUE1NEQKUldSTnBVb1VBdy81YS9nRUgraGtJK2lxM0lIZkliTDRNUGx1WS9xa2dkVzRWYlo5WWJ0aVRGaTkK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Sirvelyn",
    "homepage": "https://github.com/sirvelyn/Sirvelyn",
    "copyright": "Copyright © 2026 Sirvelyn",
    "category": "DeveloperTool",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "shortDescription": "Pixel-art terminal emulator",
    "longDescription": "A pixel-art terminal emulator for Windows. Run up to 6 terminals side by side in a split grid or as tabs, with a GPU (WebGL) renderer so full-screen TUIs stay crisp and smooth.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
